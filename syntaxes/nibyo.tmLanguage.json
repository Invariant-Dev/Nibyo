{
  "scopeName": "source.nibyo",
  "patterns": [
    {
      "name": "comment.line.number-sign.nibyo",
      "match": "#.*$"
    },
    {
      "name": "comment.block.nibyo",
      "begin": "ignore all this:",
      "end": "end ignore"
    },
    {
      "name": "keyword.control.nibyo",
      "match": "\\b(if|else|do|end|iterate|using|through|to|repeat|times|while|in the background as|wait|seconds?|return)\\b"
    },
    {
      "name": "keyword.other.nibyo",
      "match": "\\b(set|to|display|get|value|at|index|from|random)\\b"
    },
    {
      "name": "string.quoted.double.nibyo",
      "begin": "\"",
      "end": "\""
    },
    {
      "name": "constant.numeric.nibyo",
      "match": "\\b\\d+(\\.\\d+)?\\b"
    }
  ]
}