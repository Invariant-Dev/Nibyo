{
  "name": "nibyo-lang",
  "displayName": "Nibyo Language Support",
  "version": "1.0.0",
  "publisher": "yourname",
  "description": "Language support for Nibyo: The language easier than pseudocode.",
  "main": "./extension.js",
  "engines": {
    "vscode": "^1.60.0"
  },
  "categories": ["Programming Languages"],
  "activationEvents": ["onLanguage:nibyo"],
  "contributes": {
    "commands": [{
      "command": "nibyo.runFile",
      "title": "Run Nibyo File",
      "category": "Nibyo"
    }],
    "menus": {
      "editor/title": [{
        "command": "nibyo.runFile",
        "group": "navigation",
        "when": "editorLangId == nibyo"
      }],
      "editor/context": [{
        "command": "nibyo.runFile",
        "group": "navigation",
        "when": "editorLangId == nibyo"
      }]
    },
    "languages": [{
      "id": "nibyo",
      "aliases": ["Nibyo", "nibyo"],
      "extensions": [".nb", ".nibyo"],
      "configuration": "./language-configuration.json"
    }],
    "grammars": [{
      "language": "nibyo",
      "scopeName": "source.nibyo",
      "path": "./syntaxes/nibyo.tmLanguage.json"
    }]
  }
}